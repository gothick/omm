{% extends 'base.html.twig' %}

{% block title %}One Mile Matt Image {{ image.title ?? image.name }}{% endblock %}

{% block body %}
    <div class="row image">
        <div class="col mx-3 headerstrip">
            <div class="row">
                <div class="col">
                    <h2>{{ image.title ?? image.name }}</h2>
                    <p>{{ image.description |striptags|markdown }}</p>
                </div>
            </div>
            <div class="row details">
                <div class="col">
                    {% if image.wanders|length == 1 %}
                        {# TODO: We should probably be passed a wander, rather than just arbitrarily choosing the first one, though so far
                           there's only ever one wander per image #}
                        {% set wander = image.wanders | first %}
                        <p>From wander: <a href="{{ path('wanders_show', { 'id': wander.id }) }}">{{ wander }}</a></p>
                    {% endif %}
                    {# TODO: Cope with multiple related wanders; we don't have any yet. #}
                </div>
                <div class="col">
                    <p>Taken: {{ image.capturedAt| date("D j F Y H:i") }}</p>
                </div>
            </div>
            {% if next_image or prev_image %}
            <div class="row linkchain">
                {% if prev_image %}
                <div class="col prev">
                    <p><a href="{{ path('image_show', {'id': prev_image.id}) }}">&larr; Previous Image</a></p>
                </div>
                {% endif %}
                {% if next_image %}
                <div class="col next">
                    <p><a href="{{ path('image_show', {'id': next_image.id}) }}">Next Image &rarr;</a></p>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
    <div class="row mb-4">
        <div class="col">
            {#
                TODO Add an alt text property so we can be more accessible
                TODO What happens if the alt text has quotes in it?
            #}
            <img class="img-fluid w-100"
                src="{{ vich_uploader_asset(image, 'imageFile') }}"
                srcset="{{ image | srcset }}"
                sizes="(min-width: 1200px) 1140px,
                        100vw"
                 />
        </div>
    </div>

    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
    <hr/>
    <div id="adminlinks">
        <a href="{{ path('admin_image_edit', {'id': image.id}) }}">Image Edit Page</a>
    </div>
    {% endif %}
{% endblock %}
